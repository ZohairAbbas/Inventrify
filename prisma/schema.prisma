generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ShopSettings {
  id                 String   @id @default(cuid())
  shop               String   @unique
  courierifyApiKey   String?
  financifyApiKey    String?
  defaultLeadTime    Int      @default(7)
  // Safety stock: Z-score for service level (1.28=90%, 1.65=95%, 2.05=98%)
  serviceLevel       Float    @default(1.65)
  safetyStockDays    Int      @default(7)   // fallback when no variance data
  // Alert thresholds
  deadStockDays      Int      @default(60)
  deadStockMinUnits  Int      @default(20)
  // Notifications
  notificationEmail  String?
  slackWebhookUrl    String?
  whatsappNumber     String?
  timezone           String   @default("UTC")
  currency           String   @default("USD")
  theme              String   @default("emerald")
  // Incremental cursor for the Courierify returns pull (?updatedSince=). Null = never synced.
  courierifyReturnsCursor DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Supplier {
  id                String   @id @default(cuid())
  shop              String
  name              String
  contactName       String?
  email             String?
  phone             String?
  address           String?
  leadTimeDays      Int      @default(7)
  // Computed from PO history
  avgActualLeadTime Float?   // actual avg days from sent → received
  leadTimeVariance  Float?   // std dev of actual lead times
  totalPosReceived  Int      @default(0)
  notes             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  products       Product[]
  purchaseOrders PurchaseOrder[]

  @@index([shop])
}

model Product {
  id              String    @id  // Shopify variant GID
  shop            String
  productGid      String          // Parent Shopify product GID
  inventoryItemId String?         // Shopify inventory_item_id — for webhook mapping
  title           String
  variantTitle    String?
  sku             String?
  currentStock    Int       @default(0)
  reorderPoint    Int       @default(0)
  leadTimeDays    Int       @default(7)
  codReturnRate   Float     @default(0)
  avgMargin       Float     @default(0)
  avgDailySales   Float     @default(0)
  // Fulfilment pipeline — live per-SKU snapshot synced from Courierify shipment statuses.
  // Damaged is NOT here; it is derived from StockAdjustment(reason="damage"). See contract doc.
  fulfilledDelivered Int    @default(0)
  fulfilledInTransit Int    @default(0)
  fulfilledReturned  Int    @default(0)
  fulfilmentSyncedAt DateTime?
  // Safety stock — auto-computed on sync
  safetyStock     Int       @default(0)
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  forecasts        Forecast[]
  purchaseOrders   PurchaseOrderItem[]
  salesRecords     SalesRecord[]
  stockSnapshots   StockSnapshot[]
  adjustments      StockAdjustment[]
  returnRateHistory ReturnRateHistory[]
  locationStock    ProductLocationStock[]
  transferItems    StockTransferItem[]
  returnItems      ReturnItem[]

  @@index([shop])
  @@index([productGid])
  @@index([inventoryItemId])
  @@index([shop, sku])
}

// Physical stock locations synced from Shopify (source of truth for per-location inventory)
model Location {
  id                String   @id @default(cuid())
  shop              String
  shopifyLocationId String // Shopify location GID
  name              String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  stockLevels ProductLocationStock[]
  transfersFrom StockTransfer[] @relation("TransferFrom")
  transfersTo   StockTransfer[] @relation("TransferTo")

  @@unique([shop, shopifyLocationId])
  @@index([shop])
}

// Per-location stock — the real source of truth; Product.currentStock is a cached sum(onHand)
model ProductLocationStock {
  id         String   @id @default(cuid())
  shop       String
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  onHand     Int      @default(0)
  reserved   Int      @default(0) // available = onHand - reserved
  updatedAt  DateTime @updatedAt

  @@unique([productId, locationId])
  @@index([shop])
  @@index([locationId])
}

model SalesRecord {
  id        String   @id @default(cuid())
  shop      String
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  date      DateTime // midnight UTC
  quantity  Int
  createdAt DateTime @default(now())

  @@unique([productId, date])
  @@index([shop, date])
}

// Daily stock snapshots for analytics / trend charts
model StockSnapshot {
  id        String   @id @default(cuid())
  shop      String
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  date      DateTime // midnight UTC
  stock     Int
  createdAt DateTime @default(now())

  @@unique([productId, date])
  @@index([shop, date])
}

// Manual inventory adjustments with audit trail
model StockAdjustment {
  id        String   @id @default(cuid())
  shop      String
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  delta      Int      // positive=added, negative=removed
  reason     String   // damage | count_correction | sample | return | other
  note       String?
  locationId String?  // Location.id this adjustment applied to (null = legacy/primary)
  createdAt  DateTime @default(now())

  @@index([shop, productId])
}

// COD return rate per product per week (trend tracking)
model ReturnRateHistory {
  id         String   @id @default(cuid())
  shop       String
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  weekStart  DateTime // Monday midnight UTC
  returnRate Float    // 0.0–1.0
  orderCount Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([productId, weekStart])
  @@index([shop, weekStart])
}

// Seasonal events / demand multipliers
model SeasonalEvent {
  id               String   @id @default(cuid())
  shop             String
  name             String   // "Eid ul Fitr", "Ramadan", "Back to School"
  startDate        DateTime
  endDate          DateTime
  impactMultiplier Float    @default(1.0) // 1.5 = 50% demand increase
  // comma-separated Product ids this event affects (empty = all products)
  productIds       String   @default("")
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([shop, startDate])
}

model Forecast {
  id           String   @id @default(cuid())
  shop         String
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  forecastDate DateTime
  horizon      Int      // 30, 60, or 90 days
  grossDemand  Int
  netDemand    Int
  confidence   Float
  // AI enhancements
  seasonalityApplied Boolean @default(false)
  eventMultiplier    Float   @default(1.0)
  safetyStockUsed    Int     @default(0)
  createdAt    DateTime @default(now())

  @@unique([productId, horizon])
  @@index([shop])
}

model PurchaseOrder {
  id                   String    @id @default(cuid())
  shop                 String
  poNumber             String    @unique
  status               String    @default("draft") // draft | sent | received
  supplierId           String?
  supplier             Supplier? @relation(fields: [supplierId], references: [id])
  notes                String?
  totalCost            Float     @default(0)
  expectedDeliveryDate DateTime?
  actualDeliveryDate   DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  items PurchaseOrderItem[]

  @@index([shop])
  @@index([shop, status])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantityOrdered Int
  quantityReceived Int          @default(0)
  unitCost        Float         @default(0)
}

model Alert {
  id        String   @id @default(cuid())
  shop      String
  type      String   // low_stock | stockout | dead_stock | return_rate_spike | lead_time_breach
  productId String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([shop, isRead])
  @@index([shop, type])
}

// Stock transfers between locations — draft → in-transit → received
model StockTransfer {
  id             String    @id @default(cuid())
  shop           String
  transferNumber String    @unique
  status         String    @default("draft") // draft | in-transit | received
  fromLocationId String
  toLocationId   String
  fromLocation   Location  @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocation     Location  @relation("TransferTo", fields: [toLocationId], references: [id])
  notes          String?
  shippedAt      DateTime?
  receivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  items StockTransferItem[]

  @@index([shop])
  @@index([shop, status])
}

model StockTransferItem {
  id               String        @id @default(cuid())
  stockTransferId  String
  stockTransfer    StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  productId        String
  product          Product       @relation(fields: [productId], references: [id])
  quantitySent     Int
  quantityReceived Int           @default(0)
}

// Returns-to-restock queue — one row per returned line item pulled from Courierify
// (shipment where isReturnReceived=true). The merchant resolves each into the physical
// stock: restock (adds units back via a StockAdjustment) or write-off (records damage).
model ReturnItem {
  id             String   @id @default(cuid())
  shop           String
  // Courierify shipment identity — (shipmentId, sku) is the idempotency key for pulls.
  shipmentId     String
  shopifyOrderName String?
  sku            String
  productId      String?  // matched to Product by sku; null if no local match
  product        Product? @relation(fields: [productId], references: [id])
  quantity       Int      @default(1)
  returnReceivedAt DateTime?
  reasonCategory String?  // from Courierify ReturnReason.category
  status         String   @default("pending") // pending | restocked | written_off
  locationId     String?  // where it was restocked (null until resolved)
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([shipmentId, sku])
  @@index([shop, status])
}
